{
  "ui": {
    "dependsOn": [
      "sim",
      "contracts"
    ],
    "triggerPrefixes": [
      "src/app/",
      "src/game/ui/",
      "src/project/ui.js",
      "src/game/render/",
      "docs/llm/ui/"
    ],
    "requiredEntry": "docs/llm/ui/UI_TASK_ENTRY.md"
  },
  "sim": {
    "dependsOn": [
      "contracts"
    ],
    "triggerPrefixes": [
      "src/game/sim/",
      "src/game/plugin/",
      "src/core/runtime/",
      "src/project/project.logic.js",
      "docs/llm/sim/"
    ],
    "requiredEntry": "docs/llm/sim/SIM_TASK_ENTRY.md"
  },
  "contracts": {
    "dependsOn": [],
    "triggerPrefixes": [
      "src/game/contracts/",
      "src/project/contract/",
      "src/project/project.manifest.js",
      "src/project/llm/",
      "src/core/kernel/",
      "src/kernel/",
      "docs/llm/contracts/"
    ],
    "requiredEntry": "docs/llm/contracts/CONTRACT_TASK_ENTRY.md"
  },
  "testing": {
    "dependsOn": [
      "contracts"
    ],
    "triggerPrefixes": [
      "tests/",
      "tools/llm-preflight.mjs",
      "tools/run-test-suite.mjs",
      "tools/run-all-tests.mjs",
      "tools/run-foundation-visual-playwright.mjs",
      "tools/test-suites.mjs",
      "tools/evidence-runner.mjs",
      "tools/git-llm-guard.mjs",
      "tools/install-git-hooks.mjs",
      ".githooks/",
      "docs/llm/testing/"
    ],
    "requiredEntry": "docs/llm/testing/TESTING_TASK_ENTRY.md"
  },
  "versioning": {
    "dependsOn": [
      "contracts"
    ],
    "triggerPrefixes": [
      ".gitignore",
      "agents/llm-entry-sequence/",
      "README.md",
      "RUNBOOK.md",
      "package.json",
      "src/project/contract/manifest.js",
      "docs/WORKFLOW.md",
      "docs/PRODUCT.md",
      "docs/ARCHITECTURE.md",
      "docs/STATUS.md",
      "docs/traceability/",
      "docs/llm/TASK_ENTRY_MATRIX.json",
      "docs/llm/ENTRY.md",
      "docs/llm/OPERATING_PROTOCOL.md",
      "docs/llm/entry/",
      "docs/llm/versioning/"
    ],
    "requiredEntry": "docs/llm/versioning/VERSIONING_TASK_ENTRY.md"
  }
}
