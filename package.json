{
  "name": "lifexlab-game-sandbox",
  "version": "0.7.3",
  "private": true,
  "type": "module",
  "scripts": {
    "serve": "python3 -m http.server 8080",
    "hooks:install": "node tools/install-git-hooks.mjs",
    "llm:preflight:start": "node tools/llm-preflight.mjs entry --paths tests/,tools/llm-preflight.mjs,tools/run-test-suite.mjs,tools/run-all-tests.mjs --mode work",
    "llm:preflight:ack": "node tools/llm-preflight.mjs ack --paths tests/,tools/llm-preflight.mjs,tools/run-test-suite.mjs,tools/run-all-tests.mjs",
    "llm:preflight:check": "node tools/llm-preflight.mjs check --paths tests/,tools/llm-preflight.mjs,tools/run-test-suite.mjs,tools/run-all-tests.mjs",
    "test": "node tools/run-all-tests.mjs",
    "test:quick": "node tools/run-test-suite.mjs quick",
    "test:truth": "node tools/run-test-suite.mjs truth",
    "test:full": "node tools/run-all-tests.mjs"
  }
}
